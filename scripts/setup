#!/usr/bin/env bash
set -euo pipefail

unset VIRTUAL_ENV
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
MINIAPP_DIR="$ROOT_DIR/app/miniapp"
API_DIR="$ROOT_DIR/app/api"
source "$ROOT_DIR/scripts/_common.sh"

if [[ -f "$API_DIR/pyproject.toml" ]]; then
  echo "[setup] syncing backend dependencies"
  (
    cd "$API_DIR"
    run_uv "[setup] uv is required for the backend but was not found in PATH." sync --dev
  )
else
  echo "[setup] backend project not initialized yet"
fi

if [[ -f "$MINIAPP_DIR/package.json" ]]; then
  echo "[setup] installing miniapp dependencies"
  (
    cd "$MINIAPP_DIR"
    run_pnpm "[setup] pnpm is required for the miniapp but was not found in PATH." install
  )
else
  echo "[setup] miniapp project not initialized yet"
fi

if [[ -f "$ROOT_DIR/standards/skills/manifest.yaml" ]]; then
  echo "[setup] skills registry detected at standards/skills/manifest.yaml"
fi

echo "[setup] done"
